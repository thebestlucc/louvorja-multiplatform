{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LouvorJA",
  "version": "0.1.0",
  "identifier": "com.louvorja",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self' tauri: asset: http://asset.localhost; script-src 'self' https://www.youtube.com; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob: https://i.ytimg.com http://127.0.0.1:*; connect-src ipc: http://ipc.localhost http://127.0.0.1:*; media-src asset: http://asset.localhost blob: http://127.0.0.1:*; frame-src https://www.youtube.com https://www.youtube-nocookie.com",
      "freezePrototype": true,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/com.louvorja/**",
          "$APPDATA/media/**",
          "$APPLOCALDATA/media/**",
          "$APPDATA/images/**",
          "$APPDATA/covers/**",
          "$APPDATA/musics/**",
          "$HOME/**",
          "$DESKTOP/**",
          "$DOCUMENT/**",
          "$DOWNLOAD/**",
          "$PICTURE/**",
          "$VIDEO/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "resources": [
      "resources/bible/*.sqlite",
      "fonts/*.ttf"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "linux": {
      "deb": {
        "postInstallScript": "./scripts/postinst.sh"
      },
      "rpm": {
        "postInstallScript": "./scripts/postinst.sh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "",
      "endpoints": [
        "https://example.com/updater/{{target}}/{{current_version}}"
      ]
    }
  }
}
