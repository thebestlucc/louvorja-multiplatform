{
  "identifier": "desktop-capability",
  "platforms": [
    "macOS",
    "windows",
    "linux"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "window-state:default",
    "global-shortcut:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "store:default"
  ]
}