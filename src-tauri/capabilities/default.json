{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for LouvorJA main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:window:allow-create",
    "core:window:allow-close",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:window:allow-set-fullscreen",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-available-monitors",
    "core:window:allow-current-monitor",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-print",
    "opener:allow-default-urls",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "$APPDATA/**" }]
    },
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "core:path:default",
    "updater:allow-check",
    "updater:allow-install",
    "allow-music-commands",
    "allow-collection-commands",
    "allow-bible-commands",
    "allow-slide-commands",
    "allow-audio-commands",
    "allow-display-commands",
    "allow-utility-commands",
    "allow-system-commands",
    "allow-schedule-commands",
    "allow-media-library-commands"
  ]
}
